+    public void deductPoints(PointsMessage message) {
+        // 根据订单号查询积分记录,若存在则扣除(或增加负分记录）
+        PointsRecord record = pointsRecordMapper.selectOne(
+                new LambdaQueryWrapper<PointsRecord>().eq(PointsRecord::getOrderNo, message.getOrderNo())
+        );
+        if (record != null && record.getPoints() > 0) {
+            // 实际业务中可能新增一条负分记录，或直接扣减用户总积分
+            // 这里简单记录一条负分流水
+            PointsRecord deductRecord = new PointsRecord();
+            deductRecord.setUserId(message.getUserId());
+            deductRecord.setOrderNo(message.getOrderNo());
+            deductRecord.setPoints(-message.getPoints()); // 负数表示扣除
+            pointsRecordMapper.insert(deductRecord);
+
+            // 同时更新用户总积分（假设有 user_points 表）
+//            userPointsService.decreasePoints(message.getUserId(), message.getPoints());
+
+            log.info("积分扣除成功，订单号: {}, 扣除积分: {}", message.getOrderNo(), message.getPoints());
+        } else {
+            log.warn("积分记录不存在或已扣除，订单号: {}", message.getOrderNo());
+        }
+    }
 }
