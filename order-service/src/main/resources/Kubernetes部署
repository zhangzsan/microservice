            tcpSocket:
              port: 9876
            initialDelaySeconds: 30
            periodSeconds: 10
```

```yaml
# k8s/infrastructure/rocketmq/broker-statefulset.yaml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: rocketmq-broker
  namespace: microservice
spec:
  serviceName: rocketmq-broker
  replicas: 2
  selector:
    matchLabels:
      app: rocketmq-broker
  template:
    metadata:
      labels:
        app: rocketmq-broker
    spec:
      initContainers:
        - name: init-config
          image: busybox
          command: ['sh', '-c']
          args:
            - |
              cat > /etc/rocketmq/broker.conf <<EOF
              brokerClusterName = DefaultCluster
              brokerName = broker-a
              brokerId = 0
              deleteWhen = 04
              fileReservedTime = 48
              brokerRole = ASYNC_MASTER
              flushDiskType = ASYNC_FLUSH
              autoCreateTopicEnable=true
              EOF
          volumeMounts:
            - name: broker-config
              mountPath: /etc/rocketmq
      containers:
        - name: broker
          image: apache/rocketmq:5.1.4
          command: ["sh", "mqbroker"]
          args: ["-c", "/etc/rocketmq/broker.conf"]
          env:
            - name: NAMESRV_ADDR
              value: "rocketmq-namesrv-0.rocketmq-namesrv.microservice.svc.cluster.local:9876;rocketmq-namesrv-1.rocketmq-namesrv.microservice.svc.cluster.local:9876"
          ports:
            - containerPort: 10909
              name: remoting
            - containerPort: 10911
              name: ha
            - containerPort: 10912
              name: vip
          resources:
            requests:
              memory: "2Gi"
              cpu: "1000m"
            limits:
              memory: "4Gi"
              cpu: "2000m"
          volumeMounts:
            - name: broker-data
              mountPath: /home/rocketmq/store
            - name: broker-config
              mountPath: /etc/rocketmq
  volumeClaimTemplates:
    - metadata:
        name: broker-data
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: 50Gi
    - metadata:
        name: broker-config
      spec:
        accessModes: ["ReadWriteOnce"]
        resources:
          requests:
            storage: 1Gi
