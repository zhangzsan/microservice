## 6️⃣ 部署脚本

### 完整部署脚本

```bash
#!/bin/bash
# k8s/scripts/deploy.sh

set -e

NAMESPACE="microservice"
REGISTRY="your-registry"
VERSION="1.0.0"

echo "=========================================="
echo "开始部署微服务到 Kubernetes"
echo "=========================================="

# 1. 创建命名空间
echo "[1/8] 创建命名空间..."
kubectl apply -f k8s/namespace.yaml

# 2. 创建Secrets
echo "[2/8] 创建Secrets..."
kubectl apply -f k8s/secrets.yaml -n $NAMESPACE

# 3. 部署基础设施
echo "[3/8] 部署基础设施..."
kubectl apply -f k8s/infrastructure/nacos/ -n $NAMESPACE
kubectl apply -f k8s/infrastructure/mysql/ -n $NAMESPACE
kubectl apply -f k8s/infrastructure/redis/ -n $NAMESPACE
kubectl apply -f k8s/infrastructure/rocketmq/ -n $NAMESPACE

echo "等待基础设施就绪..."
kubectl rollout status statefulset/nacos -n $NAMESPACE --timeout=300s
kubectl rollout status statefulset/mysql -n $NAMESPACE --timeout=300s
kubectl rollout status statefulset/redis -n $NAMESPACE --timeout=300s
kubectl rollout status statefulset/rocketmq-namesrv -n $NAMESPACE --timeout=300s

# 4. 构建并推送Docker镜像
echo "[4/8] 构建并推送Docker镜像..."
cd ../..
mvn clean package -DskipTests

docker build -t $REGISTRY/order-service:$VERSION ./order-service
docker build -t $REGISTRY/account-service:$VERSION ./account-service
docker build -t $REGISTRY/storage-service:$VERSION ./storage-service
docker build -t $REGISTRY/points-service:$VERSION ./points-service
docker build -t $REGISTRY/api-gateway:$VERSION ./gateway

docker push $REGISTRY/order-service:$VERSION
docker push $REGISTRY/account-service:$VERSION
docker push $REGISTRY/storage-service:$VERSION
docker push $REGISTRY/points-service:$VERSION
docker push $REGISTRY/api-gateway:$VERSION

cd k8s

# 5. 部署微服务
echo "[5/8] 部署微服务..."
kubectl apply -f k8s/services/order-service/ -n $NAMESPACE
kubectl apply -f k8s/services/account-service/ -n $NAMESPACE
kubectl apply -f k8s/services/storage-service/ -n $NAMESPACE
kubectl apply -f k8s/services/points-service/ -n $NAMESPACE

# 6. 部署网关
echo "[6/8] 部署API网关..."
kubectl apply -f k8s/gateway/ -n $NAMESPACE

# 7. 配置HPA
echo "[7/8] 配置自动扩缩容..."
kubectl apply -f k8s/services/order-service/hpa.yaml -n $NAMESPACE

# 8. 验证部署
echo "[8/8] 验证部署..."
sleep 30
kubectl get pods -n $NAMESPACE
kubectl get svc -n $NAMESPACE
kubectl get ingress -n $NAMESPACE

echo "=========================================="
echo "部署完成！"
echo "=========================================="
echo "查看服务状态: kubectl get pods -n $NAMESPACE"
echo "查看服务日志: kubectl logs -f deployment/order-service -n $NAMESPACE"
echo "访问API: https://api.yourdomain.com"
```

### 回滚脚本

```bash
#!/bin/bash
# k8s/scripts/rollback.sh

set -e

NAMESPACE="microservice"
VERSION=${1:-"previous"}

echo "开始回滚到版本: $VERSION"

kubectl rollout undo deployment/order-service -n $NAMESPACE --to-revision=$VERSION
kubectl rollout undo deployment/account-service -n $NAMESPACE --to-revision=$VERSION
kubectl rollout undo deployment/storage-service -n $NAMESPACE --to-revision=$VERSION
kubectl rollout undo deployment/points-service -n $NAMESPACE --to-revision=$VERSION
kubectl rollout undo deployment/api-gateway -n $NAMESPACE --to-revision=$VERSION

echo "等待回滚完成..."
kubectl rollout status deployment/order-service -n $NAMESPACE
kubectl rollout status deployment/account-service -n $NAMESPACE
kubectl rollout status deployment/storage-service -n $NAMESPACE
kubectl rollout status deployment/points-service -n $NAMESPACE
kubectl rollout status deployment/api-gateway -n $NAMESPACE

echo "回滚完成！"
```

